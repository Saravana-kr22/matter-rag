# ---------------------------------------------------------------------------
# Matter RAG — Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is loaded automatically by the pipeline at startup.
# NEVER commit .env to version control.
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# macOS / Apple Silicon — prevent faiss-cpu + OpenBLAS segfault
# (set in shell or here; run_pipeline.py also sets these before any import)
# ---------------------------------------------------------------------------
OMP_NUM_THREADS=1
OPENBLAS_NUM_THREADS=1
TOKENIZERS_PARALLELISM=false

# ---------------------------------------------------------------------------
# GitHub (required to fetch PR diffs via the GitHub API)
# ---------------------------------------------------------------------------
GITHUB_TOKEN=ghp_your_personal_access_token_here

# ---------------------------------------------------------------------------
# Anthropic / Claude (required when llm.provider = claude_cli)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here

# ---------------------------------------------------------------------------
# Ollama (optional — only needed when llm.provider = local)
# Default: http://localhost:11434
# ---------------------------------------------------------------------------
# OLLAMA_HOST=http://localhost:11434

# ---------------------------------------------------------------------------
# PostgreSQL + pgvector (required when database.backend = postgres)
# Format: postgresql://user:password@host:port/dbname
# ---------------------------------------------------------------------------
# POSTGRES_URL=postgresql://matter_user:secret@localhost:5432/matterdb

# ---------------------------------------------------------------------------
# MATTER_RAG__ override variables (optional)
# Any config.yaml value can be overridden at runtime.
# Format: MATTER_RAG__<SECTION>__<KEY>=value
# Examples:
# ---------------------------------------------------------------------------
# MATTER_RAG__LLM__PROVIDER=local
# MATTER_RAG__DATABASE__BACKEND=chroma
# MATTER_RAG__PIPELINE__REBUILD_INDEX=true
# MATTER_RAG__PIPELINE__SEARCH_TOP_K=5
# MATTER_RAG__EMBEDDINGS__DEVICE=mps
